// ============================================================
// firestore.rules — Règles de sécurité Firestore
// À déployer via : firebase deploy --only firestore:rules
// Ou copier-coller dans la console Firebase >
//   Firestore Database > Règles
// ============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Foyers ────────────────────────────────────────────────
    match /foyers/{foyerId} {

      // Tout utilisateur authentifié peut LIRE les métadonnées
      // du foyer (pour vérifier un ID avant de rejoindre).
      // Les données réelles sont dans la sous-collection /snapshots.
      allow read: if request.auth != null;

      // Création : l'auteur doit être dans la liste des membres
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.members;

      // Mise à jour : membre existant OU ajout de soi-même
      allow update: if request.auth != null && (
        request.auth.uid in resource.data.members
        || (
          // Rejoindre un foyer : on ne peut qu'AJOUTER son propre uid
          request.resource.data.members.hasAll(resource.data.members)
          && request.resource.data.members.size() == resource.data.members.size() + 1
          && request.auth.uid in request.resource.data.members
        )
      );

      // Suppression interdite
      allow delete: if false;

      // ── Snapshots (données réelles) ────────────────────────
      // Seuls les membres du foyer peuvent lire/écrire les données.
      match /snapshots/{snapId} {
        allow read, write: if request.auth != null
          && request.auth.uid in
             get(/databases/$(database)/documents/foyers/$(foyerId)).data.members;
      }
    }
  }
}
