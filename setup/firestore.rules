rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /foyers/{foyerId} {

      // Lecture publique des métadonnées (pour vérifier un ID avant de rejoindre)
      allow read: if request.auth != null;

      // Création : l'auteur doit être dans la liste des membres
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.members;

      // Mise à jour : membre existant OU ajout de soi-même
      allow update: if request.auth != null && (
        request.auth.uid in resource.data.members
        || (
          request.resource.data.members.hasAll(resource.data.members)
          && request.resource.data.members.size() == resource.data.members.size() + 1
          && request.auth.uid in request.resource.data.members
        )
      );

      allow delete: if false;

      // Snapshots : accès réservé aux membres du foyer
      match /snapshots/{snapId} {
        allow read, write: if request.auth != null
          && request.auth.uid in
             get(/databases/$(database)/documents/foyers/$(foyerId)).data.members;
      }
    }
  }
}
